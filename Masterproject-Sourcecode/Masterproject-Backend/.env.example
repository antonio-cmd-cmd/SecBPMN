# ===== DUAL LLM CONFIGURATION =====
# Enable dual LLM system (generator + validator)
# Set to 'true' to use dual-LLM, 'false' to use legacy single-LLM
USE_DUAL_LLM=true

# Maximum iterations between generator and validator
# Recommended: 2-5 iterations
MAX_LLM_ITERATIONS=3

# ===== GENERATOR LLM CONFIGURATION =====
# Provider: 'ollama' for local or 'gemini' for cloud
GENERATOR_LLM_PROVIDER=ollama

# --- Ollama Configuration for Generator ---
GENERATOR_OLLAMA_MODEL=gpt-oss:latest
GENERATOR_OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini Configuration for Generator ---
GENERATOR_GEMINI_MODEL=gemini-2.5-flash
GENERATOR_GOOGLE_API_KEY=your_gemini_api_key_here

# Generator LLM Temperature (0.0-1.0, lower = more deterministic)
GENERATOR_LLM_TEMPERATURE=0.3

# Max Output Tokens for Generator (for Gemini only)
GENERATOR_MAX_OUTPUT_TOKENS=65536

# ===== VALIDATOR LLM CONFIGURATION =====
# Provider: 'ollama' for local or 'gemini' for cloud
VALIDATOR_LLM_PROVIDER=ollama

# --- Ollama Configuration for Validator ---
VALIDATOR_OLLAMA_MODEL=gpt-oss:latest
VALIDATOR_OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini Configuration for Validator ---
VALIDATOR_GEMINI_MODEL=gemini-2.5-flash
VALIDATOR_GOOGLE_API_KEY=your_gemini_api_key_here

# Validator LLM Temperature (0.0-1.0, lower = more strict validation)
VALIDATOR_LLM_TEMPERATURE=0.2

# Max Output Tokens for Validator (for Gemini only)
VALIDATOR_MAX_OUTPUT_TOKENS=8192

# ===== LEGACY SINGLE LLM CONFIGURATION (for backward compatibility) =====
# Only used when USE_DUAL_LLM=false

# LLM Provider Configuration
# Choose: "ollama" for local models or "gemini" for Google Cloud models
LLM_PROVIDER=ollama

# Ollama Configuration (when LLM_PROVIDER=ollama)
OLLAMA_MODEL=deepseek-r1:32b
OLLAMA_BASE_URL=http://localhost:11435

# Gemini Configuration (when LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your-google-api-key-here

# LLM Temperature (0.0 to 1.0)
LLM_TEMPERATURE=0.3

# Max Output Tokens (for Gemini - max 65536 for gemini-2.5-flash)
MAX_OUTPUT_TOKENS=65536

# ===== DATABASE CONFIGURATION =====
LANCE_DB_PATH=lance_threat_db
KNOWLEDGE_BASE_PATH=resources/knowledgeBaseLLMWithThreats.json

# ===== CONFIGURATION EXAMPLES =====

# Example 1: Both LLMs using Ollama (Local)
# USE_DUAL_LLM=true
# GENERATOR_LLM_PROVIDER=ollama
# VALIDATOR_LLM_PROVIDER=ollama
# MAX_LLM_ITERATIONS=3

# Example 2: Both LLMs using Gemini (Cloud)
# USE_DUAL_LLM=true
# GENERATOR_LLM_PROVIDER=gemini
# VALIDATOR_LLM_PROVIDER=gemini
# MAX_LLM_ITERATIONS=3

# Example 3: Mix - Generator with Gemini, Validator with Ollama
# USE_DUAL_LLM=true
# GENERATOR_LLM_PROVIDER=gemini
# VALIDATOR_LLM_PROVIDER=ollama
# MAX_LLM_ITERATIONS=3

# Example 4: Disable dual-LLM (use legacy single-LLM)
# USE_DUAL_LLM=false
# LLM_PROVIDER=ollama
