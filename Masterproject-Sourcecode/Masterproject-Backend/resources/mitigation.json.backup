    },
    {
      "title": "Monitor Remote Access from All Endpoints, Including Mobile Devices",
      "description": "Ensure monitoring and control of remote access from all devices, including mobile ones.",
      "category": "monitoring",
      "page": 3
    },
    {
      "title": "Establish a Baseline of Normal Behavior for Networks and Workforce Members",
      "description": "Create a baseline to detect anomalies in network and workforce member behavior.",
      "category": "monitoring",
