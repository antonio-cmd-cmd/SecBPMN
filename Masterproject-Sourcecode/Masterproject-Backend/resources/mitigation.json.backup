    {
      "title": "Implement Insider Risk Management Programs",
      "description": "Organizations should implement Insider Risk Management Programs (IRMPs) by collaborating with key stakeholders across various groups including Management, Human Resources, Legal Counsel, Physical Security, Information Technology, Information Security, Data Owners, and Software Engineers to mitigate insider threats effectively.",
      "category": "security",
      "page": 6
    },
    {
      "title": "Learn From Past Insider Incidents",
      "description": "Best Practice 22: Learn From Past Insider Incidents.",
      "category": "security",
      "page": 8
    },
    {
      "title": "Interactive Strategy Implementation",
      "description": "An organization must implement a multi-pronged approach with continuous feedback from stakeholders to ensure alignment with IRMP goals.",
      "category": "configuration",
      "page": 13
    },
    {
      "title": "Balancing Act in Insider Risk Management",
      "description": "Effective risk management balances people, management, and organizational dimensions to reduce insider threats to acceptable levels.",
      "category": "security",
      "page": 13
    },
    {
      "title": "Aligning IRMP with Organizational Culture",
      "description": "IRMPs must align strategies with business policies, culture, and technical environment for effective risk management.",
      "category": "configuration",
      "page": 13
    },
    {
      "title": "Organizational Culture Impact",
      "description": "Understanding how organizational culture influences risk management efforts is crucial for success.",
      "category": "management",
      "page": 13
    },
    {
      "title": "Considering Internal and External Factors",
      "description": "Effective risk management requires considering both internal (policies, processes) and external factors to balance risks.",
      "category": "organization",
      "page": 13
    },
    {
      "title": "Coordinate with Legal and Privacy Offices",
      "description": "IRMPs should work closely with legal and privacy offices to define requirements for activities using personal data.",
      "category": "privacy",
      "page": 14
    },
    {
      "title": "Location-Specific Privacy Rights",
      "description": "Design IRMP operations scoped to specific jurisdictions to manage privacy requirements, especially for multinational organizations.",
      "category": "configuration",
      "page": 14
    },
    {
      "title": "Collaborate with U.S. Counsel and Privacy Office",
      "description": "IRMPs in the U.S. should engage with general counsel and privacy office to define requirements.",
      "category": "privacy",
      "page": 14
    },
    {
      "title": "Answer Key Questions About Systems",
      "description": "IRMPs must address questions on systems using personal data, controls, recurring activities, triggers, and budgeting.",
      "category": "data management",
      "page": 14
    },
    {
      "title": "Address GDPR Challenges",
      "description": "Multinational organizations interacting with EU citizens must comply with GDPR for personal data processing.",
      "category": "security",
      "page": 14
    },
    {
      "title": "Understand GDPR Principles",
      "description": "IRMPs should align operations with GDPR Article 5 principles to ensure compliance and protect privacy.",
      "category": "data protection",
      "page": 14
    },
    {
      "title": "Rispettare i principi GDPR",
      "description": "Esegui un'analisi approfondita del GDPR e di altre leggi simili per garantire la conformità con le diverse legislazioni.",
      "category": "compliance",
      "page": 15
    },
    {
      "title": "Limitazione del processo a fini specificati",
      "description": "Assicurarsi che i dati siano raccolti solo per fini specificati, espliciti e legittimi.",
      "category": "data",
      "page": 15
    },
    {
      "title": "Minimizzazione dei dati",
      "description": "Raccogli soltanto i dati essenziali per gli scopi previsti, evitando di accumulare informazioni inutilizzate.",
      "category": "data",
      "page": 15
    },
    {
      "title": "Accuratezza e aggiornamento dei dati",
      "description": "Sicurarsi che i dati siano corretti e aggiornati, rimuovendo o rettificando quelli inesatti.",
      "category": "data",
      "page": 15
    },
    {
      "title": "Limitazione del periodo di conservazione",
      "description": "Mantieni i dati solo per il tempo necessario agli scopi specificati.",
      "category": "configuration",
      "page": 15
    },
    {
      "title": "Sicurezza e confidenzialità",
      "description": "Implementa misure tecniche e organizzative per proteggere i dati da accessi non autorizzati.",
      "category": "security",
      "page": 15
    },
    {
      "title": "Risposta dinamica a nuove regolamentazioni",
      "description": "Resta aggiornato sulle novità legali e regolamentari, in particolare per organizzazioni statunitensi.",
      "category": "compliance",
      "page": 15
    },
    {
      "title": "Know and Protect Your Critical Assets",
      "description": "Identify and protect critical assets that provide the organization with a competitive advantage. Critical assets include tangible and intangible elements such as people, information, technology, facilities, critical services, and processes. These assets are crucial for maintaining confidentiality, integrity, and availability, impacting the organization's ability to support essential missions and business functions. Monitor where data is stored and transmitted to prevent unauthorized access or removal.",
      "category": "security",
      "page": 18
    },
    {
      "title": "Inventario esauriente degli asset critici",
      "description": "Creare un inventario dettagliato degli asset critici rispondendo a una serie di domande specifiche, inclusi servizi, processi, accessi autorizzati e valutazioni di costo in caso di perdita.",
      "category": "security",
      "page": 19
    },
    {
      "title": "Ruolo del IRMP nel gestire i rischi interni",
      "description": "IlIRMP collabora con gli asset owner per identificare, prioritizzare e proteggere gli asset critici attraverso un processo strutturato di valutazione e monitoraggio.",
      "category": "security",
      "page": 19
    },
    {
      "title": "Valutazione del rischio secondo NIST",
      "description": "Eseguire una valutazione del rischio che include la categoriazione dei sistemi, la scelta di controlli di sicurezza e l'implementazione di misure protettive, seguendo i 6 step del framework di gestione del rischio di NIST.",
      "category": "security",
      "page": 19
    },
    {
      "title": "Assess Security Controls",
      "description": "Ensure security controls are implemented correctly, operate as intended, and meet system security requirements.",
      "category": "security",
      "page": 20
    },
    {
      "title": "Authorize System Operation Based on Risk",
      "description": "Authorize information system operation after assessing risk to organizational assets and determining its acceptability.",
      "category": "security",
      "page": 20
    },
    {
      "title": "Monitor Security Controls Continuously",
      "description": "Continuously monitor and assess security controls, document changes, conduct impact analyses, and report system state.",
      "category": "security",
      "page": 20
    },
    {
      "title": "Inventory Organizational Assets",
      "description": "Answer key questions about data types, devices, and locations to understand assets needing protection.",
      "category": "asset management",
      "page": 20
    },
    {
      "title": "Refer to NIST and FIPS Guidelines",
      "description": "Use NIST SP 800-60 Vol2 and FIPS PUB 199 for categorizing information based on security objectives.",
      "category": "configuration",
      "page": 20
    },
    {
      "title": "Use Metrics to Rank Assets",
      "description": "Consider metrics like restoration time, loss impact, mission effect, failure probability, and asset popularity.",
      "category": "asset management",
      "page": 20
    },
    {
      "title": "Apply Pairwise Ranking Method",
      "description": "Rank assets by comparing two at a time using numerical ratings for prioritization.",
      "category": "asset management",
      "page": 20
    },
    {
      "title": "Create a Service-Based Inventory",
      "description": "Identify critical services required for the organization's mission. Establish a hierarchy of assets starting with top-level services and branch into supporting information, hardware, and software assets.",
      "category": "configuration",
      "page": 21
    },
    {
      "title": "Perform a Hardware-Based Inventory",
      "description": "Use hardware-based assets managed by IT to start the asset inventory. Collect details on supported software, applications running on servers, and contacts for each item.",
      "category": "configuration",
      "page": 21
    },
    {
      "title": "Update Asset Information",
      "description": "After identifying assets, ask IT to add any unidentified assets and their business owners' contact information. Business owners should identify authorized access, granting/revoking processes, emergency contacts, asset value, and regulatory requirements.",
      "category": "configuration",
      "page": 21
    },
    {
      "title": "Assign Asset Attributes",
      "description": "Once the inventory is complete, assign a set of attributes to each asset to determine its priority.",
      "category": "configuration",
      "page": 21
    },
    {
      "title": "Classificazione degli asset",
      "description": "L'organizzazione deve definire attributi come ambiente (es. produzione, sviluppo), categorizzazione sicurezza (confidenzialità, integrità, disponibilità) e criticità.",
      "category": "configuration",
      "page": 22
    },
    {
      "title": "Condurre un Privacy Impact Assessment (PIA)",
      "description": "È raccomandato condurre una PIA o DPIA in conformità al GDPR, inclusi descrittivi del processing, valutazione della necessità e proporzionalità, rischi per i diritti dei soggetti e misure di protezione.",
      "category": "privacy",
      "page": 22
    },
    {
      "title": "Ruolo dell'impiegatore nel PIA",
      "description": "Nel rapporto impiegatore/impiegato, l'impiegatore deve condurre il PIA come controller del processing dei dati personali.",
      "category": "compliance",
      "page": 22
    },
    {
      "title": "Riconoscimento di indirizzi IP dinamici come dati personali",
      "description": "Gli indirizzi IP dinamici possono essere considerati dati personali se possono identificare un individuo in combinazione con altre informazioni, conformemente al GDPR.",
      "category": "privacy",
      "page": 22
    },
    {
      "title": "Ottieni l'approvazione del leadership",
      "description": "È necessario ottenere il supporto dal leadership per dedicare tempo, denaro e risorse alle attività di identificazione e priorizzazione degli asset critici dell'organizzazione.",
      "category": "risk management",
      "page": 23
    },
    {
      "title": "Utilizza metriche appropriate per identificare gli asset critici",
      "description": "Determinare cosa costituisca un asset critico richiede l'uso di metriche specifiche e non solo la semplice dichiarazione da parte degli stakeholder.",
      "category": "risk management",
      "page": 23
    },
    {
      "title": "Definisci chiaramente lo scope degli asset critici",
      "description": "Capire e contenere l'ambito degli asset critici, specialmente in contesti cloud, remote o virtualizzati.",
      "category": "risk management",
      "page": 23
    },
    {
      "title": "Ottieni tempo e funding sufficienti",
      "description": "Sicurarsi di avere i mezzi necessari per condurre un'inventario completo degli asset, giustificando il costo con l'importanza dellaattività e i rischi associati al suo non completamento.",
      "category": "risk management",
      "page": 23
    },
    {
      "title": "Mantieni un'inventario preciso e aggiornato",
      "description": "Effettuare controlli periodici (semestrali o annuali) e auditor di routine per assicurarsi che l'inventario degli asset rimanga accurato.",
      "category": "risk management",
      "page": 23
    },
    {
      "title": "Identify Critical Assets",
      "description": "Identify critical business services, supporting processes, and assets.",
      "category": "asset management",
      "page": 24
    },
    {
      "title": "Describe Organization's Information",
      "description": "Describe the nature of information by consulting data owners and users across the organization.",
      "category": "data governance",
      "page": 24
    },
    {
      "title": "Identify Legal Requirements",
      "description": "Determine legal and regulatory requirements for protecting critical assets.",
      "category": "compliance",
      "page": 24
    },
    {
      "title": "Emergency Contacts for Assets",
      "description": "Identify emergency points of contact for all critical assets.",
      "category": "incident response",
      "page": 24
    },
    {
      "title": "Calculate Asset Loss Value",
      "description": "Calculate the present value for the loss or replacement of each asset.",
      "category": "risk assessment",
      "page": 24
    },
    {
      "title": "Track Access Permissions",
      "description": "Track who has what kind of access for each asset.",
      "category": "access control",
      "page": 24
    },
    {
      "title": "Maintain Access Guidance",
      "description": "Maintain guidance for granting and revoking access for each critical asset.",
      "category": "access control",
      "page": 24
    },
    {
      "title": "Monitor Assets",
      "description": "Identify types of monitoring capabilities that allow each critical asset to be controlled and audited.",
      "category": "monitoring",
      "page": 24
    },
    {
      "title": "Prioritize Assets",
      "description": "Prioritize assets and data to determine high-value targets.",
      "category": "risk assessment",
      "page": 24
    },
    {
      "title": "Develop a Formalized Insider Risk Management Program (IRMP)",
      "description": "An IRMP is an organization’s designated resource for mitigating insider threats. It uses a risk management approach and requires proactive measures, including role-based training, defined roles, and criteria for identifying risks and recommending mitigations.",
      "category": "security",
      "page": 26
    },
    {
      "title": "Formalized and Defined IRMP",
      "description": "The program should include elements such as directives, authorities, a mission statement, leadership intent, governance, and a budget.",
      "category": "security",
      "page": 27
    },
    {
      "title": "Organization-Wide Participation",
      "description": "The program should have active participation from all organizational components that use data access and sharing. Senior leadership should provide visible support for the program.",
      "category": "security",
      "page": 27
    },
    {
      "title": "Oversight of Program Compliance and Effectiveness",
      "description": "A governance structure, such as an IRMP working group or change control board, should help formulate standards and operating procedures for the IRMP and recommend changes to existing practices and procedures.",
      "category": "security",
      "page": 27
    },
    {
      "title": "Confidential Reporting Procedures and Mechanisms",
      "description": "These mechanisms enable reporting of suspicious activity while ensuring legitimate whistleblowers are not inhibited or inappropriately monitored.",
      "category": "security",
      "page": 27
    },
    {
      "title": "Insider Threat Incident Response Plan",
      "description": "This plan must detail more than just a referral process to outside investigators. It should provide comprehensive details for responding to incidents.",
      "category": "security",
      "page": 27
    },
    {
      "title": "Comunicazione degli eventi di minaccia interna",
      "description": "Le informazioni sugli eventi dovrebbero essere condivise in modo appropriato con le componenti organizzative corrette, mantenendo la confidenzialità e la privacy del personale fino a quando le accuse non siano pienamente sostenute. Questo include tendenze, modelli e eventi futuri probabili per modificare politiche, procedure, formazione ecc.",
      "category": "communication and information sharing",
      "page": 28
    },
    {
      "title": "Protezione delle libertà civili e diritti alla privacy del personale",
      "description": "Il Consiglio Legale deve esaminare le decisioni e azioni del programma IRMP a tutti i livelli di sviluppo, implementazione e operazione.",
      "category": "security and privacy",
      "page": 28
    },
    {
      "title": "Integrazione con la gestione del rischio aziendale",
      "description": "L'IRMP deve assicurarsi che tutti gli aspetti della gestione del rischio aziendale includano considerazioni sulla minaccia interna (non solo attacchi esterni) e l'organizzazione dovrebbe considerare l'establishment di un componente standalone per la gestione del rischio interno.",
      "category": "risk management",
      "page": 28
    },
    {
      "title": "Pratiche relative alla gestione delle entità esterne affidabili (TEE)",
      "description": "Queste pratiche includono accordi, contratti e processi revisionati per la prevenzione, rilevamento e risposta alle minacce interne.",
      "category": "external partner management",
      "page": 28
    },
    {
      "title": "Infrastruttura per prevenzione, rilevamento e risposta",
      "description": "Questa infrastruttura include componenti come difese di rete, host, fisiche, strumenti e processi.",
      "category": "secure infrastructure",
      "page": 28
    },
    {
      "title": "Formazione e coscienza sulla minaccia interna",
      "description": "La formazione comprende tre aspetti: (1) formazione di consapevolezza per tutto il personale, (2) formazione per i membri del programma IRMP, e (3) formazione basata sul ruolo per specialisti che potrebbero osservare aspetti specifici degli eventi di minaccia interna.",
      "category": "training and awareness",
      "page": 28
    },
    {
      "title": "Strumenti, tecniche e pratiche per la raccolta e analisi dei dati",
      "description": "Questi strumenti includono il monitoraggio delle attività degli utenti, la raccolta e l'analisi dei dati. È richiesta documentazione dettagliata per garantire il conformarsi alla privacy del personale.",
      "category": "data management",
      "page": 28
    },
    {
      "title": "Politiche, procedure e pratiche di IRMP",
      "description": "L'IRMP deve avere documenti formali che dettagliano tutti gli aspetti del programma, inclusa la sua missione, minacce, direttive e procedure standard.",
      "category": "program management",
      "page": 28
    },
    {
      "title": "Incentivi positivi",
      "description": "Le organizzazioni dovrebbero attirare il comportamento desiderabile mediante incentivi basati su motivazioni positive, concentrandosi sull'engagement del lavoro, supporto organizzativo e connessione al lavoro.",
      "category": "personnel management",
      "page": 28
    },
    {
      "title": "Establish Insider Risk Management Program (IRMP)",
      "description": "An IRMP helps detect, prevent, and respond to insider incidents. It involves cross-functional teams from different areas of the organization to handle sensitive information with discretion.",
      "category": "security",
      "page": 29
    },
    {
      "title": "Prepare for Insider Incidents Consistently and Timely",
      "description": "IRMP members must understand roles, authority, coordination, reporting, actions to take, and improvements to ensure effective response.",
      "category": "security",
      "page": 29
    },
    {
      "title": "Handle Sensitive Information Discreetly",
      "description": "IRMP teams must treat cases with discretion due to potential career impacts and protect privacy and confidentiality.",
      "category": "privacy",
      "page": 29
    },
    {
      "title": "Balance Information Sharing and Privacy",
      "description": "Ask all involved organizational groups to contribute their threat detection data and ideas, but have only a small, core IRMP team receive and analyze that information.",
      "category": "security",
      "page": 30
    },
    {
      "title": "Align IRMP Directly with Senior Leadership",
      "description": "The IRMP is most effective when it directly reports to the President/CEO/Director/Secretary or their Principal Deputy, ensuring commitment from senior leadership and unfettered access to needed data sources.",
      "category": "risk management",
      "page": 30
    },
    {
      "title": "Identify Trusted Agents for Data Feeds",
      "description": "Each business unit should have a trusted agent who can provide data feeds or additional information. Trusted agents must undergo a background check and sign an IRMP nondisclosure agreement (NDA) before assuming this role.",
      "category": "insider threat management",
      "page": 31
    },
    {
      "title": "IRMP Requests Data and Conducts Own Analysis",
      "description": "The IRMP should request data from other departments (e.g., facility access logs from Physical Security team) but perform its own analysis to encourage cooperation.",
      "category": "insider threat management",
      "page": 31
    },
    {
      "title": "Involve Team Members Based on Threat Type",
      "description": "The organization should determine which IRMP team members must be involved for each type of prevention, detection, or response effort. Inclusion in a response may vary based on the escalation level.",
      "category": "insider threat management",
      "page": 31
    },
    {
      "title": "Regular Team Meetings for Proactive and Reactive Responses",
      "description": "The IRMP team should meet regularly to discuss detected anomalies (proactive response) and allegations of potential insider activity (reactive response). Meetings can be conducted in person or virtually.",
      "category": "insider threat management",
      "page": 31
    },
    {
      "title": "Use Secure Communication Methods",
      "description": "The IRMP team should use secure communication methods, such as videoconferencing or encrypted emails, to collaborate across locations. Security procedures include encryption using public key infrastructure.",
      "category": "security",
      "page": 31
    },
    {
      "title": "Procedimenti di crittografia per email",
      "description": "Utilizzare procedure che specificano l'uso di crittografia robusta, come PGP. Le email devono essere decrittografate solo brevemente, lette offline, archiviate in forma crittografata e la versione decrittografata eliminata in modo sicuro.",
      "category": "security",
      "page": 32
    },
    {
      "title": "Piani alternativi per riunioni elettroniche",
      "description": "Prevedere piani alternativi per riunioni elettroniche nel caso di attacchi o monitoraggio interno.",
      "category": "security",
      "page": 32
    },
    {
      "title": "Confidenzialità durante le indagini",
      "description": "Maintenere la confidenzialità delle informazioni relative a indagini IRMP per proteggere la privacy e nascondere l'indagine dal dipendente sospettato.",
      "category": "confidentiality",
      "page": 32
    },
    {
      "title": "Reticenza delle accuse",
      "description": "Tenere confidenziali le indagini e discuterle solo con chi ha un bisogno legittimo di sapere, poiché le accuse non possono essere completamente ritrattate.",
      "category": "confidentiality",
      "page": 32
    },
    {
      "title": "Richiesta di dati durante indagini",
      "description": " richiedere dati da un insieme più grande per evitare di allertare il sospetto o il proprietario dei dati.",
      "category": "investigations",
      "page": 32
    },
    {
      "title": "Audi casuale come pratica standard",
      "description": "Includere audi casuali nelle politiche e procedure operativi standard per rilevare minacce non identificate e fornire copertura non allertante per le richieste di dati.",
      "category": "threat detection",
      "page": 32
    },
    {
      "title": "Engagement del personale per prevenire insiders",
      "description": "Pratiche per migliorare l'engagement del personale, come la gestione basata sulle competenze, possono ridurre il rischio di comportamenti dannosi.",
      "category": "personnel management",
      "page": 32
    },
    {
      "title": "Screening and Privacy in HR Inquiries",
      "description": "HR must carefully screen information involved in inquiries and release only the minimum amount of information necessary on a need-to-know basis to ensure workforce member privacy.",
      "category": "security",
      "page": 33
    },
    {
      "title": "Behavioral Science SME Embedded in HR",
      "description": "The HR team can include a behavioral science subject matter expert (SME) who is embedded or works closely with the Insider Risk Management Program (IRMP).",
      "category": "security",
      "page": 33
    },
    {
      "title": "HR Watch List for Personnel",
      "description": "The HR team can use internal findings to develop a watch list of personnel and release it to certain members of the IA and IRMP teams so they know which logs to review.",
      "category": "security",
      "page": 33
    },
    {
      "title": "Behavioral Indicators for Insider Threats",
      "description": "Behavioral indicators identified by CERT researchers, such as repeated policy violations, disruptive behavior, financial difficulty, and job performance problems, can be used to signal potential malicious insider activities.",
      "category": "security",
      "page": 33
    },
    {
      "title": "HR Notification for Exiting Employees",
      "description": "When a workforce member resigns or leaves the organization, HR must notify members of the IT team so they can perform enhanced monitoring on the exiting individual.",
      "category": "security",
      "page": 33
    },
    {
      "title": "IRMP Inquiry for Insider Resignation",
      "description": "HR notifies the CSIRT and IRMP, who conduct an inquiry of past and present online activity and project future online activity, with a particular focus on logs of activity for 30 days before and after the insider resigned.",
      "category": "security",
      "page": 33
    },
    {
      "title": "Increased Monitoring for Financial Difficulty",
      "description": "The IRMP increases monitoring of financial transactions and data, such as personally identifiable information (PII), that could be sold when a workforce member is experiencing extreme financial difficulty or has a sudden, unexplained change in financial status.",
      "category": "security",
      "page": 33
    },
    {
      "title": "Monitoraggio di insider a alto rischio",
      "description": "Le squadre IT e IA devono collaborare per individuare un piano di monitoraggio degli insider a alto rischio, identificando tutti i sistemi e le informazioni accessibili da tali dipendenti. È essenziale che i log di controllo registri siano sufficientemente dettagliati per rilevare le seguenti informazioni: chi ha eseguito l'azione, cosa è stato fatto, quando è avvenuto l'evento e dove.",
      "category": "security",
      "page": 34
    },
    {
      "title": "Utilizzo di soluzioni SIEM per il monitoraggio",
      "description": "Le squadre IT e IA dovrebbero implementare una soluzione SIEM (Security Information and Event Management) per raccogliere e correlare tutti gli eventi di sicurezza. Questo sistema può essere personalizzato per identificare pattern specifici o estrazione di eventi in base a criteri definiti.",
      "category": "security",
      "page": 34
    },
    {
      "title": "Correlazione di log fisici e IT",
      "description": "La squadra di Sicurezza Fisica deve collaborare con la squadra IA per raccogliere log di accesso fisico. Quando possibile, le registrazioni video e altri tipi di log devono essere correlati per aiutare a identificare minacce.",
      "category": "security",
      "page": 34
    },
    {
      "title": "Funzionamento dell'IRMP con politiche definite",
      "description": "L'IRMP (Incident Response Management Program) deve operare in base a politiche ben definite e applicate in modo costante. Riunioni regolari consentono di garantire il compliance con le politiche e migliorano la situazione d'impresa grazie alla collaborazione interdipartimentale.",
      "category": "incident management",
      "page": 34
    },
    {
      "title": "Programmi di prevenzione della violenza nel luogo di lavoro",
      "description": "I programmi di prevenzione della violenza nel luogo di lavoro, come quello del USDA, richiedono un team di valutazione delle minacce composto da membri di vari dipartimenti che lavorano attivamente per identificare e mitigare potenziali rischi.",
      "category": "safety",
      "page": 34
    },
    {
      "title": "Management Support for IRMP",
      "description": "Continuous support from all levels of management is essential for the success of the Insider Risk Management Program (IRMP). Financial backing and genuine commitment are necessary to avoid situations where support wanes, either due to perceived ineffectiveness or higher priorities.",
      "category": "security",
      "page": 35
    },
    {
      "title": "Avoiding IRMP Misuse",
      "description": "Prevent both intentional and unintentional misuse of the IRMP. Ensure that program functions are not subverted for personal goals or accidentally leading to privacy breaches, especially concerning GDPR regulations.",
      "category": "security",
      "page": 35
    },
    {
      "title": "Finding Team Participants",
      "description": "Even small organizations without dedicated workforce members can establish an IRMP by designating contacts and ensuring they know their roles.",
      "category": "governance",
      "page": 36
    },
    {
      "title": "Avoiding Negative Unintended Consequences",
      "description": "IRMP planners must anticipate negative impacts, monitor for them, and mitigate as needed during change management.",
      "category": "risk mitigation",
      "page": 36
    },
    {
      "title": "Recognizing the Right to Rectification",
      "description": "Under GDPR, workforce members can request data corrections; IRMP should handle these requests while managing associated risks.",
      "category": "compliance",
      "page": 36
    },
    {
      "title": "Governance Structure for IRMP",
      "description": "A mature governance structure maintains knowledge, supports stakeholders, monitors practices, communicates successes, performs budget reviews, updates procedures, and improves continuously.",
      "category": "governance",
      "page": 36
    },
    {
      "title": "Implementare un Programma di Gestione del Rischio Interno (IRMP)",
      "description": "Un team dedicato al rischio interno dovrebbe creare politiche e procedure per controlli di ammissione, monitoraggio di comportamenti anomali e processi di detenzione.",
      "category": "security",
      "page": 37
    },
    {
      "title": "Utilizzare soluzioni SIEM con regole personalizzate",
      "description": "Le regole personalizzate nelle soluzioni SIEM aiutano a rilevare attività sospette, come accessi extra-giornata o l'uso remoto di account amministrativi.",
      "category": "monitoring",
      "page": 37
    },
    {
      "title": "Monitoraggio attento dell'accesso remoto",
      "description": "È consigliabile monitorare con attenzione l'accesso remoto, come descritto nella Best Practice 13, per prevenire potenziali minacce interne.",
      "category": "security",
      "page": 37
    },
    {
      "title": "Effettuare controlli di background approfonditi",
      "description": "I controlli di background possono prevenire la Selezione di dipendenti con precedenti condanne per frode o attività dannose.",
      "category": "admission",
      "page": 37
    },
    {
      "title": "Monitoraggio costante del comportamento anomalo",
      "description": "Monitorareattività sospette, come download eccessivi di file confidenziali, per rilevare potenziali minacce interne.",
      "category": "monitoring",
      "page": 37
    },
    {
      "title": "Ottieni approvazione legale iniziale",
      "description": "Ottieni l'approvazione legale iniziale per tutte le politiche e pratiche previste. Richiedi al legal counsel di identificare i requisiti legali per operare un IRMP, specificamente ciò che è consentito o meno.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Estabilisci protocolli di revisione legale",
      "description": "Stabilisci protocolli periodici e basati su eventi per la revisione e l'approvazione legali, ad esempio revisioni semestrali o richieste di assistenza legale basate su eventi specifici.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Documenta la definizione di incidente minaccia interna",
      "description": "Documentare la definizione dell'organizzazione di un incidente di minaccia interna e identificare i triggers necessari che possano classificare l'evento come una violazione dei dati, ad esempio se riguarda l'esfiltrazione di PII.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Definisci un piano di risposta cross-functionale",
      "description": "Definire un piano di risposta a incidenti di minaccia interna che descrive chi è responsabile di cosa e in quale periodo durante la risposta a un evento di minaccia interna.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Considera opzioni per il trasferimento del rischio",
      "description": "Considerare opzioni per il trasferimento del rischio, come provider di assicurazioni o servizi di cibersegurança che possano essere contrattualmente impegnati a gestire e rimediare a un incidente.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Formalizza il programma IRMP",
      "description": "Formalizzare il programma IRMP nominando un funzionario senior come gestore del programma, che possa monitorare e rispondere ai rischi interni.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Definisci indicatori di minaccia interna",
      "description": "Definire e_deploy indicatori di minaccia interna in un hub analitico che possa rilevare potenziali precursori di attività di minaccia interna, mantenendo il monitoraggio in tempo reale e assicurandosi che le liste degli indicatori siano contestualizzate ai gruppi utenti e agli asset critici.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Definisci metriche di rischio interno",
      "description": "Definire e_deploy metriche di rischio interno in un hub analitico che possano aggregare e contestualizzare indicatori di minaccia interna per identificare pattern di comportamento associati a minacce interne.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Mantieni contatti frequenti tra stakeholder IRMP",
      "description": "Mantenere contatti frequenti e stretti tra i stakeholders del programma IRMP per preservare uno stato di pronto.",
      "category": "security",
      "page": 38
    },
    {
      "title": "Ensure Policies Are Fair and Consistently Enforced",
      "description": "Organizations must ensure their policies and controls are fair, communicated to the entire workforce, and consistently enforced. This reduces the chance of inadvertent damage or resentment leading to harmful actions.",
      "category": "security",
      "page": 41
    },
    {
      "title": "Provide Clear Documentation and Training",
      "description": "Administrative controls should include concise and coherent documentation, including justification for policies. Regular workforce training on policies, their implementation, and enforcement is essential.",
      "category": "documentation",
      "page": 41
    },
    {
      "title": "Clarify Administrative Controls on Sensitive Topics",
      "description": "Organizations should be particularly clear about administrative controls regarding the use of systems, privileged accounts, ownership of information, performance evaluations, grievance processes, and acceptable workplace behavior.",
      "category": "configuration",
      "page": 41
    },
    {
      "title": "Fornitura di copie delle politiche agli nuovi membri del personale",
      "description": "Gli individui che entrano nell'organizzazione dovrebbero ricevere una copia delle politiche dell'organizzazione, che definiscano (1) ciò che si aspetta da loro come membri del personale e (2) le conseguenze previste in caso di violazione delle politiche. L'organizzazione deve raccogliere e conservare la prova che ogni individuo abbia letto ed accettato le politiche dell'organizzazione.",
      "category": "configuration",
      "page": 42
    },
    {
      "title": "Politiche speciali per utenti privilegiati",
      "description": "Gli amministratori di sistemi e chiunque altro con accesso non limitato ai sistemi informativi (utenti privilegiati) presentano un rischio unico. L'organizzazione dovrebbe considerare la creazione di una politica specifica per utenti privilegiati riguardante l'utilizzo accettabile o le regole di comportamento. La politica deve essere ribadita annualmente con gli utenti privilegiati e si dovrebbe implementare una soluzione per gestire i relativi account privilegiati.",
      "category": "security",
      "page": 42
    },
    {
      "title": "Prevenzione di insoddisfazioni del personale",
      "description": "La documentazione chiara delle politiche e controlli può prevenire i malintesi che possono portare a aspettative non soddisfatte. L'adeguata enforceability delle politiche garantisce che i membri del personale non percepire che vengano trattati in modo diverso o peggiore degli altri. La gestione deve essere esempio, altrimenti si creerà l'impressione che (1) non tutti siano sottoposti alle stesse norme e (2) la gestione non supporti pienamente le politiche o procedure.",
      "category": "cultural",
      "page": 42
    },
    {
      "title": "Gestione del cambiamento organizzativo",
      "description": "L'organizzazione deve riconoscere che il cambiamento è particolarmente stressante per i membri del personale, ammettere il rischio associato e mitigare tale rischio comunicando chiaramente ciò che si aspetta dal personale in futuro.",
      "category": "management",
      "page": 42
    },
    {
      "title": "Implementazione di Procedure Chiare per lo Sviluppo del Software",
      "description": "Le organizzazioni dovrebbero creare, distribuire e far rispettare linee guida ben definite per lo sviluppo del software.",
      "category": "configuration",
      "page": 43
    },
    {
      "title": "Programma di Gestione dei Cambiamenti",
      "description": "Per i sistemi mission-critical, è consigliabile avere un programma di gestione dei cambiamenti che richieda la sottomissione del codice sorgente.",
      "category": "security",
      "page": 43
    },
    {
      "title": "Prevenzione della Concentrazione del Conoscimento",
      "description": "Evitare che una singola persona detenga il monopolio delle informazioni cruciali sulle infrastrutture di rete.",
      "category": "security",
      "page": 43
    },
    {
      "title": "Documentazione e Condivisione di Accessi Critici",
      "description": "Tutti i punti di accesso e le autorizzazioni devono essere documentati e condivisi tra più persone.",
      "category": "configuration",
      "page": 43
    },
    {
      "title": "Management Advocacy for Policies",
      "description": "Ensure senior management advocates, enforces, and complies with all organizational policies to ensure effectiveness.",
      "category": "governance",
      "page": 44
    },
    {
      "title": "Uniform Management Compliance",
      "description": "All levels of management must comply with policies; noncompliance can undermine policy adherence among subordinates.",
      "category": "governance",
      "page": 44
    },
    {
      "title": "Clear Communication of Policy Exceptions",
      "description": "Communicate exceptions to policies clearly to the entire workforce to maintain transparency and consistency.",
      "category": "communication",
      "page": 44
    },
    {
      "title": "Policy Briefings for Workforce",
      "description": "Management should brief the workforce on all policies, requiring employees, contractors, and TEEs to sign acceptable-use and behavior policies annually or upon significant changes.",
      "category": "compliance",
      "page": 44
    },
    {
      "title": "Reaffirming Nondisclosure Agreements",
      "description": "Use policy signings as an opportunity to reaffirm nondisclosure agreements with employees, contractors, and TEEs.",
      "category": "compliance",
      "page": 44
    },
    {
      "title": "Easy Access to Policies",
      "description": "Ensure policies are easily accessible, such as by posting them on the organization’s internal website.",
      "category": "communication",
      "page": 44
    },
    {
      "title": "Annual Refresher Training",
      "description": "Mandate annual refresher training covering various areas including HR, legal, physical security, and policy changes to keep employees informed.",
      "category": "employee training",
      "page": 44
    },
    {
      "title": "Consistent Policy Enforcement",
      "description": "Enforce policies consistently across the workforce to prevent perceptions of favoritism. HR should establish consequences for violations.",
      "category": "compliance",
      "page": 44
    },
    {
      "title": "Monitoraggio del comportamento sospetto durante il processo di assunzione",
      "description": "Gli organismi devono identificare proattivamente e gestire immediatamente comportamenti sospetti o disturbanti per ridurre il rischio di minacce interne.",
      "category": "security",
      "page": 46
    },
    {
      "title": "Indagini approfondite durante l'assunzione",
      "description": "Effetuare controlli approfonditi sul passato penale, controlli del credito, verifica delle credenziali e colloqui con i precedenti datori di lavoro per valutare la capacità del candidato.",
      "category": "security",
      "page": 46
    },
    {
      "title": "Considerazioni legali durante le indagini",
      "description": "Prendere in considerazione le esigenze legali, includendo l'obbligo di notificare il candidato e ottenere il consenso, conformemente alle migliori prassi dell'EEOC e alle regolamentazioni statali e locali.",
      "category": "legal",
      "page": 46
    },
    {
      "title": "Protezione delle informazioni durante le indagini",
      "description": "Sicureizzare le informazioni ottenute attraverso i controlli di background in conformità al GDPR e alle direttive dell'Unione Europea.",
      "category": "privacy",
      "page": 46
    },
    {
      "title": "Assegnazione di livelli di rischio ai ruoli",
      "description": "Valutare i ruoli per livello di rischio e indagare approfonditamente i candidati per i ruoli con un livello di rischio elevato o che richiedono una maggiore fiducia.",
      "category": "security",
      "page": 46
    },
    {
      "title": "Ricontrolli periodici",
      "description": "Effettuare ricontrolli quando i dipendenti accedono a ruoli con un livello di rischio maggiore, assicurandosi il rispetto delle esigenze legali.",
      "category": "security",
      "page": 46
    },
    {
      "title": "Formazione dei supervisori",
      "description": "Investire in formazioni per i supervisori affinché siano in grado di riconoscere e gestire comportamenti inappropriati o preoccupanti.",
      "category": "training",
      "page": 46
    },
    {
      "title": "Consistent Policy Enforcement",
      "description": "Organizations must consistently enforce policies and procedures for all workforce members to prevent rule violations from escalating.",
      "category": "security",
      "page": 47
    },
    {
      "title": "Monitor Financial Situations",
      "description": "Be alert to financial problems or unexplained gains among employees as they may indicate potential insider threats.",
      "category": "security",
      "page": 47
    },
    {
      "title": "Enable Reporting Mechanisms",
      "description": "Create policies allowing employees to report concerning behavior and ensure consistent monitoring without bias.",
      "category": "employee relations, security",
      "page": 47
    },
    {
      "title": "Thorough Investigation of Reports",
      "description": "Investigate all reports of concerning behavior until an appropriate response is determined.",
      "category": "security",
      "page": 47
    },
    {
      "title": "Prevent Employee Migration Without Documentation",
      "description": "Disruptive employees should not evade documentation by moving within the organization.",
      "category": "configuration, procedural guidelines",
      "page": 47
    },
    {
      "title": "Treat Threats as Concerning Behavior",
      "description": "Consider any threats or negative sentiments as concerning and address them promptly.",
      "category": "security",
      "page": 47
    },
    {
      "title": "Evaluate Access and Offer Support",
      "description": "When an employee exhibits concerning behavior, evaluate their access to assets and offer support options like EAP.",
      "category": "access management, employee support",
      "page": 47
    },
    {
      "title": "Legal Compliance in Monitoring",
      "description": "Ensure all monitoring activities are legal by consulting counsel and respecting privacy laws.",
      "category": "legal compliance, security",
      "page": 47
    },
    {
      "title": "Maintaining Workforce Morale",
      "description": "Ensure monitoring activities do not lead to a 'big brother' perception that can reduce morale and productivity.",
      "category": "personnel morale",
      "page": 48
    },
    {
      "title": "Using Arrest Records in Employment Decisions",
      "description": "Avoid using arrest records instead of convictions for employment decisions, as it is legally questionable. Consult legal counsel before using or disclosing arrest record information.",
      "category": "hiring practices",
      "page": 48
    },
    {
      "title": "Monitoring Communications Legally",
      "description": "Monitor only legally allowable communications, especially avoiding private communications with doctors and lawyers. In the EU, provide additional notices for monitoring email or electronic correspondence.",
      "category": "compliance and privacy",
      "page": 48
    },
    {
      "title": "Contractor Background Checks",
      "description": "Require contractors to perform background checks on their employees as part of the contractual agreement.",
      "category": "external control",
      "page": 48
    },
    {
      "title": "Thorough Vetting of Executives",
      "description": "Ensure thorough vetting of all executives, including checking for any prior convictions or fraudulent activities.",
      "category": "internal surveillance",
      "page": 48
    },
    {
      "title": "Verify Employee Credentials Before Hiring",
      "description": "Organizations must verify any claims of certifications or credentials made by candidates during the hiring process to ensure they are legitimate.",
      "category": "security",
      "page": 49
    },
    {
      "title": "Conduct Thorough Background Checks",
      "description": "Organizations should perform comprehensive background checks on potential employees, including criminal history and verifying claims, before extending job offers.",
      "category": "security",
      "page": 49
    },
    {
      "title": "Implement Proper Account Management Policies",
      "description": "Organizations must establish and enforce strict account management policies to prevent unauthorized access and ensure accountability for all user accounts.",
      "category": "configuration",
      "page": 49
    },
    {
      "title": "Anonymous Reporting System",
      "description": "Implement an anonymous reporting system to encourage employees to report concerns without fear of reprisal.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Thorough Background Checks",
      "description": "Ensure potential workforce members undergo a thorough background check, including criminal and credit checks.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Encourage Reporting of Suspicious Behavior",
      "description": "Encourage workforce members to report suspicious behavior to appropriate personnel for further investigation.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Confidential Reporting Method",
      "description": "Provide a confidential method for reporting suspicious behavior without repercussions.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Investigate and Document Behavior",
      "description": "Investigate and document all suspicious or disruptive behavior to ensure proper handling of potential threats.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Consistent Enforcement of Policies",
      "description": "Enforce policies and procedures consistently for all workforce members to maintain a secure environment.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Offer Employee Assistance Programs (EAP)",
      "description": "Consider offering an EAP to help workforce members deal with personal issues confidentially, which can prevent potential insider threats.",
      "category": "security",
      "page": 50
    },
    {
      "title": "Definire e Comunicare Politiche Chiare",
      "description": "Definire politiche chiare riguardo al comportamento, codice di vestiario, uso degli asset IT, orari di lavoro, sviluppo professionale e risoluzione dei conflitti. Queste devono essere comunicate ai nuovi dipendenti il primo giorno.",
      "category": "personnel management",
      "page": 52
    },
    {
      "title": "Conoscenza delle Politiche da Tutti i Dipendenti",
      "description": "Assicurarsi che tutti i dipendenti, nuovi e veterani, siano a conoscenza delle politiche e delle conseguenze di eventuali violazioni.",
      "category": "personnel management",
      "page": 52
    },
    {
      "title": "Applicazione Equa e Consistente delle Politiche",
      "description": "Applicare le politiche in modo equo e consistente per mantenere un ambiente di lavoro armonioso e prevenire sentimenti di ingiustizia.",
      "category": "personnel management",
      "page": 52
    },
    {
      "title": "Gestione Transparent delle Raising e Promozioni",
      "description": "Informare i dipendenti in anticipo se non saranno concessi rialzi o promozioni come previsto, offrendo una spiegazione. Mantenere trasparenza riguardo alle aspettative contrattuali.",
      "category": "personnel management",
      "page": 52
    },
    {
      "title": "Sicurezza durante Periodi di Incertezza Finanziaria",
      "description": "Durante periodi come la fine di un periodo di valutazione o il termine di un contratto, incrementare le misure di sicurezza per prevenire comportamenti anomali.",
      "category": "security",
      "page": 52
    },
    {
      "title": "Surveillance durante Riduzioni del Personale",
      "description": "Deployare misure di sicurezza avanzate quando i dipendenti sono a conoscenza di una riduzione del personale ma non sanno chi sarà licenziato.",
      "category": "security",
      "page": 52
    },
    {
      "title": "Implementare programmi di assistenza agli impiegati",
      "description": "Gli organizzazioni dovrebbero offrire servizi come i Programmi di Assistenza agli Impiegati (EAP) per aiutare i dipendenti a gestire stress finanziari o personali, riducendo il rischio di minacce interne.",
      "category": "security",
      "page": 53
    },
    {
      "title": "Monitorare i dipendenti infelici",
      "description": "Dopo avvertimenti o sanzioni, gli organizzazioni dovrebbero includere i dipendenti infelici in una 'watch list' per prevenire potenziali furti di dati.",
      "category": "security",
      "page": 53
    },
    {
      "title": "Adottare accordi di non divulgazione e non concorrenza",
      "description": "Gli organizzazioni dovrebbero richiedere ai dipendenti di firmare NDA (Non-Disclosure Agreements) e altri accordi legali per prevenire la fuga di informazioni.",
      "category": "security",
      "page": 53
    },
    {
      "title": "Enhance Monitoring for Personnel Issues",
      "description": "Monitor workforce members with pending personnel issues in accordance with organizational policies and laws.",
      "category": "monitoring, security",
      "page": 54
    },
    {
      "title": "Additional Auditing Controls",
      "description": "Enable additional auditing and monitoring controls as outlined in policies and procedures to detect unauthorized activities.",
      "category": "auditing, security",
      "page": 54
    },
    {
      "title": "Regular Audit Log Reviews",
      "description": "Frequently review audit logs to identify activities outside the normal scope of work for early detection of potential threats.",
      "category": "control, monitoring",
      "page": 54
    },
    {
      "title": "Limit Access to Logs",
      "description": "Restrict access to log files only to individuals who require knowledge of such information.",
      "category": "secure access, control",
      "page": 54
    },
    {
      "title": "Transparent Communication from Management",
      "description": "All levels of management must regularly communicate organizational changes to maintain transparency and allow workforce members to plan effectively.",
      "category": "communication, management",
      "page": 54
    },
    {
      "title": "Considerare le minacce provenienti da dipendenti e entità esterne affidabili negli accertamenti del rischio a livello aziendale",
      "description": "Le organizzazioni devono sviluppare una strategia di sicurezza basata sul rischio per proteggere i propri asset critici da minacce interne ed esterne, incluse entità esterne affidabili (TEE), come servizi outsource e provider cloud. Tutti i risorse dell'organizzazione devono comprendere le implicazioni di una compromissione del sistema o della perdita di dati critici.",
      "category": "security",
      "page": 56
    },
    {
      "title": "Valutare rischi legati agli insider e fornitori esterni",
      "description": "Organizzazioni devono riconoscere il rischio rappresentato dagli insiders, inclusi contractor, consulenti e provider di servizi cloud. Gli insider hanno accesso privilegiato a asset critici e devono essere considerati come minacce interne. Contratti con fornitori devono prevedere livelli commisurati di controllo sul recruiting, protezione dati e policy di sicurezza. Organizzazioni possono influenzare provider IT controllando le loro pratiche, analizzando indicazioni governative, comprendendo rischi, scegliendo di accettare o cambiare fornitori, testando patch e mantenendo controllo su installazioni.",
      "category": "security",
      "page": 57
    },
    {
      "title": "Strategia e piano base per EDM",
      "description": "Organizzazioni dovrebbero stabilire una strategia e un piano base per la gestione delle dipendenze esterne (EDM).",
      "category": "security",
      "page": 58
    },
    {
      "title": "Processi chiave per identificare, priorizzare, monitorare e tracciare dipendenze esterne",
      "description": "Organizzazioni dovrebbero implementare processi chiave per gestire le dipendenze esterne.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Indirizzi e procedure per la formazione di relazioni con entità esterne",
      "description": "Organizzazioni dovrebbero avere indirizzi e procedure chiari per la formazione di relazioni con entità esterne.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Approccio per gestire e governare le relazioni esistenti con entità esterne",
      "description": "Organizzazioni dovrebbero adottare un approccio strutturato per la gestione e il governo delle relazioni con entità esterne.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Supervisione, reporting e correzione del rendimento delle entità esterne",
      "description": "Organizzazioni dovrebbero eseguire una supervisione continua,_reporting e correzione del rendimento delle entità esterne.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Approccio per migliorare i processi e il programma di EDM",
      "description": "Organizzazioni dovrebbero avere un approccio per la continua miglioramento dei loro processi e programmi di EDM.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Verifiche di background durante fusione/acquisizione",
      "description": "Organizzazioni acquirenti dovrebbero eseguire verifiche di background sui membri del personale dell'organizzazione acquisita prima delle decisioni di impiego.",
      "category": "security",
      "page": 58
    },
    {
      "title": "Lock accounts immediately upon employment change notification",
      "description": "Organizations should lock accounts before notifying employees or contractors of changes in their employment terms to prevent potential malicious activities.",
      "category": "security",
      "page": 59
    },
    {
      "title": "Separation of duties for backup processes",
      "description": "Implement a clear separation between regular administrators and those responsible for system backups. Regular admins should not have access to backup media or processes.",
      "category": "security",
      "page": 59
    },
    {
      "title": "Sign Nondisclosure Agreements",
      "description": "All workforce members and third-party entities (TEEs) should sign NDAs upon hiring and termination.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Workplace Violence Prevention Documentation",
      "description": "Ensure all employees and TEEs sign workplace violence prevention or appropriate behavior documentation upon hire.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Routine Re-acknowledgment of Policies",
      "description": "All workforce members and TEEs should regularly re-acknowledge agreements and policies such as AUP, social media policy, mobile device policy, and intellectual property (IP) policy.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Background Checks on TEEs' Workforce",
      "description": "Ensure each TEE performs background checks on all workforce members who will have access to your organization’s systems or information. These background checks should be commensurate with your organization’s own policies and required as a contractual obligation.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Background Checks During Mergers/Acquisitions",
      "description": "Perform background checks on all workforce members to be acquired during mergers or acquisitions, at a level commensurate with your organization’s policies.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Prevent Unnecessary Printing of Sensitive Documents",
      "description": "Avoid printing sensitive documents unless required for business purposes. Electronic documents are easier to track and secure.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Limit Connections with TEEs' Systems",
      "description": "Avoid direct connections with the information systems of TEEs if possible. Provide task-related data without granting access to your organization’s internal network.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Restrict Backup Access",
      "description": "Restrict access to the system backup process to only administrators, controlling privileged access effectively.",
      "category": "security",
      "page": 60
    },
    {
      "title": "Prohibit Personal Items in Secure Areas",
      "description": "Prohibit personal items in secure areas because they can be used to conceal company property or to copy and store the organization’s data.",
      "category": "security",
      "page": 61
    },
    {
      "title": "Conduct Risk Assessment for Critical Systems",
      "description": "Conduct a risk assessment of all systems to identify critical data, business processes, and mission-critical systems. Include insiders and TEEs as part of the assessment. See NIST SP 800-30 for guidance.",
      "category": "risk management",
      "page": 61
    },
    {
      "title": "Implement Data Encryption Solutions",
      "description": "Implement data encryption solutions that encrypt data seamlessly, restrict encryption tools to authorized users, and restrict decryption of organization-encrypted data to authorized users.",
      "category": "data protection",
      "page": 61
    },
    {
      "title": "Separation of Duties for Administrators",
      "description": "Implement a clear separation of duties between regular administrators and those responsible for backup and restoration.",
      "category": "access control",
      "page": 61
    },
    {
      "title": "Restrict Administrator Access to Backup Processes",
      "description": "Forbid regular administrators from having access to system backup media or electronic backup processes.",
      "category": "security",
      "page": 61
    },
    {
      "title": "Be Especially Vigilant Regarding Social Media",
      "description": "Organizations should provide training, policies, and procedures about how workforce members should use social media to mitigate risks of social engineering and insider threats.",
      "category": "security",
      "page": 63
    },
    {
      "title": "Prohibit Posting of Sensitive Information",
      "description": "Organizations should have policies that prohibit workforce members from posting about organizational projects or other sensitive information, even if it seems harmless.",
      "category": "security",
      "page": 64
    },
    {
      "title": "Establish Social Media Policies and Procedures",
      "description": "Organizations must establish policies and procedures to protect against insider threats related to social media usage. These should define acceptable and unacceptable participation in social media by workforce members.",
      "category": "security",
      "page": 64
    },
    {
      "title": "Use Bogus Password Recovery Information",
      "description": "To mitigate risks from password recovery, users can use bogus information for password recovery that is unique to each site. This reduces the vulnerability of having a single set of recovery information used across multiple sites.",
      "category": "security",
      "page": 64
    },
    {
      "title": "Include Social Engineering Training",
      "description": "Organizations should include social engineering training in their security awareness programs. This training should explain how information from social media can be used to harm individuals or organizations, and could include live demonstrations of data collection without embarrassing workforce members.",
      "category": "training",
      "page": 64
    },
    {
      "title": "Ensure Legal Compliance in Social Media Policies",
      "description": "Social media policies must be legal. Organizations should avoid language that prohibits posts about nonpublic or confidential information without clarification, restricts harmful statements about the organization, or threatens discipline for policy violations.",
      "category": "legality",
      "page": 64
    },
    {
      "title": "Monitoraggio cauteloso di social media",
      "description": "Organizzazioni che monitorano social media devono fare attenzione a non punire o licenziare dipendenti per discorsi online su condizioni di lavoro, come stipendi o lamentele contro superiori. Usare social media potrebbe rivelare informazioni su classi protette (es. razza, disabilità, genere), esponendo all'accusa di discriminazione.",
      "category": "security",
      "page": 65
    },
    {
      "title": "Etablimento e monitoraggio di policy",
      "description": "Organizzazioni devono stabilire, monitorare e applicare policy per il contenuto online. È difficile controllare ciò che dipendenti pubblicano su social media, quindi è necessario allenamento con approcci personalizzati e addestramento sulle politiche.",
      "category": "configuration",
      "page": 65
    },
    {
      "title": "Classificazione dei dati",
      "description": "Organizzazioni devono avere una policy di classificazione che stabilisce protezioni per differenti livelli di sensibilità. Richiede un'analisi degli informazioni e addestramento su tutti i livelli.",
      "category": "security",
      "page": 65
    },
    {
      "title": "Monitoraggio legale di social media",
      "description": "Monitoraggio deve essere effettuato con consulenza legale, dato che il paesaggio giuridico evolve e le politiche devono essere aggiornate in base alle modifiche.",
      "category": "compliance",
      "page": 65
    },
    {
      "title": "Limitazione della dipendenza da social media",
      "description": "Organizzazioni con dipendenti EU o TEE devono limitare l'uso di social media come fonte dati. GDPR concede il diritto alla cancellazione, quindi individui potrebbero rimuovere contenuti che danneggiano la reputazione.",
      "category": "configuration",
      "page": 65
    },
    {
      "title": "Verifica di credenziali online",
      "description": "Individui tendono a fidarsi troppo di informazioni trovate online. È cruciale verificare le credenziali di chi si presenta come esperto, per evitare truffe o violazioni di sicurezza.",
      "category": "data validation",
      "page": 65
    },
    {
      "title": "Protezione informazioni sensibili online",
      "description": "Dati personali e informazioni sensitive pubblicate su social media possono essere compromessi. È essenziale proteggere password, geolocalizzazione e informazioni personali per prevenire attacchi.",
      "category": "security",
      "page": 65
    },
    {
      "title": "Train workforce on information disclosure risks",
      "description": "Organizations should train their employees about the dangers of sharing personal or organizational information online, as it can lead to account compromises.",
      "category": "training",
      "page": 66
    },
    {
      "title": "Establish social media policy",
      "description": "Create a policy that defines acceptable uses of social media and prohibits discussing sensitive information online.",
      "category": "policy",
      "page": 66
    },
    {
      "title": "Include social media awareness training",
      "description": "Integrate social media awareness into the organization's security training programs to educate employees on safe practices.",
      "category": "training",
      "page": 66
    },
    {
      "title": "Encourage reporting suspicious activities",
      "description": "Promote the reporting of suspicious emails or calls to the security team, who can monitor patterns and issue alerts.",
      "category": "security",
      "page": 66
    },
    {
      "title": "Monitor social media use",
      "description": "Consider monitoring social media activity but ensure it is done in accordance with legal guidelines.",
      "category": "monitoring",
      "page": 66
    },
    {
      "title": "Struttura gestionale per ridurre lo stress",
      "description": "Organizzare la gestione in modo da minimizzare lo stress e i errori del personale, comprendendo la psicologia del lavoro e creando un ambiente positivo.",
      "category": "management",
      "page": 68
    },
    {
      "title": "Focus sulle esiti produttivi",
      "description": "Concentrarsi su risultati produttivi piuttosto che solo sulla quantità di lavoro, riducendo lo stress.",
      "category": "management",
      "page": 68
    },
    {
      "title": "Politiche flessibili per il personale",
      "description": "Adottare politiche che danno più tempo al personale per raggiungere obiettivi missionari.",
      "category": "management",
      "page": 68
    },
    {
      "title": "Gestione umanizzata",
      "description": "Adottare una gestione responsiva e orientata alle persone, piuttosto che solo ai progetti.",
      "category": "management",
      "page": 68
    },
    {
      "title": "Pianificazione preventiva",
      "description": "Programmare tempo per pianificare attività e generare nuove idee Beneficio dell'organizzazione.",
      "category": "management",
      "page": 68
    },
    {
      "title": "Manage Employee Stress Levels",
      "description": "Organizations should address workforce stress to mitigate insider threats. High stress can lead to mistakes or malicious actions that damage the organization. Reducing stress, lowering workload, and encouraging quality outcomes can prevent such incidents.",
      "category": "security",
      "page": 69
    },
    {
      "title": "Etablire une culture de travail basée sur des indicateurs adaptés",
      "description": "Établir une culture de travail qui évalue le succès en fonction d'indicateurs appropriés pour l'environnement de travail. Par exemple, les travailleurs spécialisés peuvent mesurer leur succès en fonction des résultats et de l'efficacité plutôt que d'indicateurs mieux adaptés à une ligne de production.",
      "category": "work/culture",
      "page": 70
    },
    {
      "title": "Encourager les travailleurs à réfléchir avant d'agir",
      "description": "Encourager les membres du personnel à réfléchir à travers des projets, des actions et des déclarations avant de s'y engager.",
      "category": "work/action",
      "page": 70
    },
    {
      "title": "Créer un environnement sans多任务处理",
      "description": "Créer un environnement qui encourage les membres du personnel à se concentrer sur une chose à la fois, plutôt que de faire plusieurs tâches en même temps.",
      "category": "efficiency/work",
      "page": 70
    },
    {
      "title": "Offrir des moyens de se détendre aux travailleurs stressés",
      "description": "Fournir des méthodes pour soulager le stress, comme les massages, les jours de congé, les jeux ou les activités sociales.",
      "category": "wellness/psychological",
      "page": 70
    },
    {
      "title": "Surveiller régulièrement les charges de travail des salariés",
      "description": "Surveiller régulièrement les charges de travail des salariés pour s'assurer qu'elles sont proportionnées à leurs compétences et aux ressources disponibles.",
      "category": "efficiency/monitoring",
      "page": 70
    },
    {
      "title": "Incorporate Insider Threat Awareness into Periodic Security Training",
      "description": "Conduct periodic security training for all workforce members to promote awareness of insider risks, including understanding that insiders do not fit a single profile and can exhibit various behavioral characteristics associated with high risk.",
      "category": "security",
      "page": 73
    },
    {
      "title": "Awareness Training for Negligent Behavior",
      "description": "Organizations should train their workforce to recognize characteristics such as high risk tolerance, multitasking leading to mistakes, excessive sharing of personal or proprietary information on social media, and lack of attention to detail.",
      "category": "security",
      "page": 74
    },
    {
      "title": "Recognizing Social Engineering Tactics",
      "description": "The entire workforce should be trained to identify malicious use of social engineering tactics aimed at financial gain, including attempts to gain unauthorized access via accounts and passwords.",
      "category": "security",
      "page": 74
    },
    {
      "title": "Annual Security Training Program",
      "description": "Security training should be conducted annually, with additional focus during National Insider Threat Awareness Month in September, including activities like quizzes and presentations.",
      "category": "training",
      "page": 74
    },
    {
      "title": "Comprehensive Insider Risk Topics in Training",
      "description": "Training programs should cover topics such as HR policies, legal issues, physical security procedures, data protection, IT security measures, and software engineering best practices.",
      "category": "training",
      "page": 74
    },
    {
      "title": "Training Focus on Critical Assets",
      "description": "Train workforce to protect customer information and processes by securing accounts, auditing access, enforcing policies, safeguarding servers, and ensuring data availability.",
      "category": "security training",
      "page": 75
    },
    {
      "title": "Detect Disruptive Behavior",
      "description": "Encourage workforce to detect and report disruptive behavior by colleagues.",
      "category": "employee monitoring",
      "page": 75
    },
    {
      "title": "Monitor Policy Adherence",
      "description": "Ensure workforce follows organizational policies and controls.",
      "category": "policy enforcement",
      "page": 75
    },
    {
      "title": "Control System Changes",
      "description": "Monitor and control changes to prevent malicious code installation.",
      "category": "access control",
      "page": 75
    },
    {
      "title": "Separate Duties",
      "description": "Require separation of duties between those modifying accounts and approving modifications.",
      "category": "access control",
      "page": 75
    },
    {
      "title": "Report Security Violations",
      "description": "Train workforce to report security violations related to facilities and assets.",
      "category": "security awareness",
      "page": 75
    },
    {
      "title": "Proactive Incident Planning",
      "description": "Plan for potential incident response proactively.",
      "category": "incident management",
      "page": 75
    },
    {
      "title": "Confidential Reporting Mechanism",
      "description": "Provide a confidential way for employees to report security issues without fear of repercussions.",
      "category": "employee support",
      "page": 75
    },
    {
      "title": "Acknowledge Acceptable Use Policies",
      "description": "Require yearly acknowledgment of AUPs at training events.",
      "category": "policy enforcement",
      "page": 75
    },
    {
      "title": "Protect Information and Assets",
      "description": "Teach workforce to protect information and assets, including procedures for anonymous reporting.",
      "category": "asset protection",
      "page": 75
    },
    {
      "title": "Inform on Confidentiality of IP",
      "description": "Educate employees about the confidentiality and integrity of IP and consequences of compromise.",
      "category": "intellectual property",
      "page": 75
    },
    {
      "title": "Implementare un sistema di classificazione delle informazioni",
      "description": "L'organizzazione dovrebbe considerare l'adozione di un sistema di classificazione che definisce categorie di informazioni e il modo in cui ciascuna categoria deve essere protetta. Ad esempio, il Governo degli Stati Uniti utilizza un sistema che includeategorie come Non Classificato, Confidenziale, Segreto e Top Secret.",
      "category": "security",
      "page": 76
    },
    {
      "title": "Educazione sui salari e miglioramento carriera",
      "description": "Utilizzare la formazione per stabilire aspettative chiare riguardo ai salari e all'enhancemeneto della carriera, al fine di ridurre il discontento.",
      "category": "human resources management",
      "page": 76
    },
    {
      "title": "Formazione regolare del personale",
      "description": "L'organizzazione deve determinare con quale frequenza effettuare la formazione e come misurare la sua efficacia, tenendo conto delle difficoltà nel discutere di incidenti precedenti senza rivelare informazioni sensibili.",
      "category": "training",
      "page": 76
    },
    {
      "title": "Melioramento della cultura organizzativa",
      "description": "Se l'organizzazione ha una cultura che non valuta la sicurezza delle informazioni, il personale potrebbe resistere all'implementazione di concetti presentati durante la formazione. Per superare questa sfida, è possibile ottenere l'approvazione del personale e utilizzare casi studiosi per dimostrare la possibilità di attacchi.",
      "category": "organizational culture",
      "page": 76
    },
    {
      "title": "Develop and Implement Enterprise-wide Training Program",
      "description": "Create a comprehensive training program that covers insider risk topics with senior management support and participation.",
      "category": "training",
      "page": 77
    },
    {
      "title": "Security Awareness for New Employees",
      "description": "Require all new employees to complete security awareness and insider threat training before system access.",
      "category": "onboarding",
      "page": 77
    },
    {
      "title": "Inclusive Training for Non-Technical Roles",
      "description": "Provide specialized training for roles like janitorial staff, covering scenarios such as social engineering and document security.",
      "category": "training",
      "page": 77
    },
    {
      "title": "Annual Training and Awareness Campaigns",
      "description": "Conduct annual training sessions and use campaigns like quizzes or posters to maintain awareness.",
      "category": "awareness",
      "page": 77
    },
    {
      "title": "Anonymous Reporting Mechanism with Incentives",
      "description": "Set up anonymous reporting for security incidents and reward those who contribute positively.",
      "category": "reporting",
      "page": 77
    },
    {
      "title": "Periodic Security Inspections",
      "description": "Infosec teams should conduct regular inspections, addressing issues privately to encourage a positive security culture.",
      "category": "security",
      "page": 77
    },
    {
      "title": "Rewarding Good Security Practices",
      "description": "Acknowledge and reward employees who demonstrate good security practices with certificates or small incentives.",
      "category": "morale",
      "page": 77
    },
    {
      "title": "Best Practice 9",
      "description": "Mapping to Standards",
      "category": "security",
      "page": 78
    },
    {
      "title": "Implement Strict Password Policies",
      "description": "Ensure all passwords are strong and do not share them with anyone.",
      "category": "security",
      "page": 80
    },
    {
      "title": "Lock Workstation Before Stepping Away",
      "description": "Workforce members should lock their workstations before leaving them unattended.",
      "category": "security",
      "page": 80
    },
    {
      "title": "Block Visual Access to Passwords",
      "description": "Ensure that screens are not visible when typing passwords to prevent shoulder surfing.",
      "category": "security",
      "page": 80
    },
    {
      "title": "Limitazione degli account condivisi",
      "description": "Gli account condivisi devono essere utilizzati solo quando realmente necessari, poiché ostacolano la tracciabilità e l'attribuzione delle attività individuali.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Utilizzo di strumenti SAPM",
      "description": "Quando necessari, utilizzare strumenti di gestione delle password per account condivisi (SAPM) che automatizzano i processi e impongono controlli.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Segnalazione degli accessi non autorizzati",
      "description": "I membri del personale devono segnalare tutti i tentativi o sospetti di accesso non autorizzato agli account.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Revoca immediata degli accessi",
      "description": "Revocare immediatamente gli accessi al termine del rapporto di lavoro per ridurre il rischio di accessi non autorizzati.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Isolamento dei sistemi di accesso guest",
      "description": "I sistemi utilizzati da membri esterni devono essere isolati dal resto degli account dell'organizzazione.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Audi periodiche degli account",
      "description": "Eseguire audit periodici per identificare account sospetti, come quelli di backdoor o condivisi.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Documentazione delle privilegi",
      "description": "Documento rigoroso di tutti i privilegi degli utenti per facilitare il processo di revoca degli accessi al momento del termine.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Uso di sistemi centralizzati di gestione degli account",
      "description": "Utilizzare sistemi centralizzati come LDAP per ridurre il rischio di dimenticanza o mancato controllo degli account.",
      "category": "configuration",
      "page": 81
    },
    {
      "title": "Applicazione delle politiche ai TEE",
      "description": "Le stesse politiche di sicurezza devono applicarsi agli account dei fornitori e degli esterni.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Attribuzione univoca degli account",
      "description": "Ogni account deve essere attribuibile a un singolo individuo, evitando account condivisi e gestendo correttamente i contratti con gli esterni.",
      "category": "security",
      "page": 81
    },
    {
      "title": "Change Passwords Upon Departure",
