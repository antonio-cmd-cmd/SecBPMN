    },
    {
      "title": "Enforce Separation of Duties and Least Privilege",
      "description": "Apply the principles of separation of duties and least privilege to minimize risks.",
      "category": "security",
      "page": 3
    },
    {
      "title": "Define Explicit Security Agreements for Cloud Services",
      "description": "Ensure clear security agreements, especially regarding access restrictions and monitoring capabilities for cloud services.",
